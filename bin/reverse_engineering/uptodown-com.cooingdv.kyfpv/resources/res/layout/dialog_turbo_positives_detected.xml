<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:paddingLeft="15dp"
        android:paddingTop="15dp"
        android:paddingRight="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="15dp">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:background="@drawable/bg_dialog"
            android:paddingTop="@dimen/margin_l"
            android:paddingBottom="@dimen/margin_l"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/margin_l">
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/vector_vt_report_safe"/>
            <TextView
                android:textSize="@dimen/text_size_l"
                android:textColor="@color/text_primary"
                android:id="@+id/tv_title_dialog_turbo_positives_detected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_l"
                android:layout_marginTop="@dimen/margin_s"
                android:layout_marginRight="@dimen/margin_l"
                android:text="@string/label_uptodown_protect"
                android:layout_marginHorizontal="@dimen/margin_l"/>
            <TextView
                android:textSize="@dimen/text_size_l"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:id="@+id/tv_description_dialog_turbo_positives_detected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_l"
                android:layout_marginTop="@dimen/margin_l"
                android:layout_marginRight="@dimen/margin_l"
                android:layout_marginBottom="@dimen/margin_l"
                android:text="@string/positive_file_found"
                android:layout_marginHorizontal="@dimen/margin_l"
                android:layout_marginVertical="@dimen/margin_l"/>
            <RelativeLayout
                android:id="@+id/rl_vt_report"
                android:background="@drawable/shape_bg_virustotal_warning"
                android:padding="@dimen/margin_l"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_l"
                android:layout_marginRight="@dimen/margin_l"
                android:layout_marginHorizontal="@dimen/margin_l">
                <ImageView
                    android:id="@+id/iv_vt_warning"
                    android:layout_width="@dimen/icon_size_m"
                    android:layout_height="@dimen/icon_size_m"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/vector_vt_report_warning"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_l"
                    android:layout_toEndOf="@+id/iv_vt_warning">
                    <TextView
                        android:textSize="@dimen/font_size_16"
                        android:textColor="@color/text_primary"
                        android:ellipsize="end"
                        android:id="@+id/tv_vt_warning_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:text="@string/vt_report_warning_title"
                        android:maxLines="3"/>
                    <TextView
                        android:textSize="@dimen/text_size_m"
                        android:textColor="@color/text_secundary"
                        android:ellipsize="end"
                        android:id="@+id/tv_vt_warning_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:maxLines="2"/>
                    <TextView
                        android:textSize="@dimen/text_size_m"
                        android:textColor="@color/text_secundary"
                        android:ellipsize="end"
                        android:id="@+id/tv_vt_warning_latest_scan_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:maxLines="1"/>
                </LinearLayout>
            </RelativeLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_vt_warning_positives"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_l"
                android:layout_marginTop="@dimen/margin_m"
                android:layout_marginRight="@dimen/margin_l"
                android:layout_marginHorizontal="@dimen/margin_l"/>
            <TextView
                android:id="@+id/tv_action_dialog_turbo_positives_detected"
                android:layout_width="match_parent"
                android:layout_marginLeft="@dimen/margin_l"
                android:layout_marginTop="@dimen/margin_l"
                android:layout_marginRight="@dimen/margin_l"
                android:text="@string/download_anyways"
                android:paddingStart="@dimen/margin_l"
                android:paddingEnd="@dimen/margin_l"
                android:layout_marginHorizontal="@dimen/margin_l"
                style="@style/DialogButtonsStyle"/>
        </LinearLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/iv_close_dialog_turbo_positives_detected"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:contentDescription="@string/close"
        android:layout_alignParentEnd="true"
        android:elevation="@dimen/button_elevation"
        app:srcCompat="@drawable/vector_cross_close_popup"/>
</RelativeLayout>
