<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/box_positive"
        android:background="@drawable/shape_circular_yellow"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginTop="2dp"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/margin_m"/>
    <TextView
        android:textSize="@dimen/text_size_m"
        android:textColor="@color/text_primary"
        android:ellipsize="end"
        android:id="@+id/tv_virus_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_toStartOf="@+id/tv_virus_type_badge"
        android:layout_toEndOf="@+id/box_positive"/>
    <TextView
        android:textSize="@dimen/text_size_s"
        android:textColor="@color/text_secundary"
        android:ellipsize="end"
        android:id="@+id/tv_antivirus_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.5dp"
        android:maxLines="1"
        android:layout_below="@+id/tv_virus_name"
        android:layout_toStartOf="@+id/tv_virus_type_badge"
        android:layout_toEndOf="@+id/box_positive"/>
    <TextView
        android:textSize="@dimen/text_size_s"
        android:textColor="@color/text_primary"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_virus_type_badge"
        android:background="@drawable/shape_bg_yellow"
        android:paddingLeft="@dimen/margin_m"
        android:paddingTop="2dp"
        android:paddingRight="@dimen/margin_m"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/margin_m"
        android:layout_alignParentEnd="true"
        android:paddingHorizontal="@dimen/margin_m"
        android:paddingVertical="2dp"/>
</RelativeLayout>
