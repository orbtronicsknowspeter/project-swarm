<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_vt_warning_header"
        android:background="@drawable/shape_bg_virustotal_warning"
        android:padding="@dimen/margin_l"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_vt_warning"
            android:layout_width="@dimen/icon_size_m"
            android:layout_height="@dimen/icon_size_m"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            app:srcCompat="@drawable/vector_vt_report_warning"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_l"
            android:layout_toEndOf="@+id/iv_vt_warning">
            <TextView
                android:textSize="@dimen/font_size_16"
                android:textColor="@color/text_primary"
                android:ellipsize="end"
                android:id="@+id/tv_vt_warning_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vt_report_warning_title"/>
            <TextView
                android:textSize="@dimen/text_size_m"
                android:textColor="@color/text_secundary"
                android:ellipsize="end"
                android:id="@+id/tv_vt_warning_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/text_size_m"
                android:textColor="@color/text_secundary"
                android:ellipsize="end"
                android:id="@+id/tv_vt_warning_latest_scan_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_vt_warning_positives"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_m"/>
    <TextView
        android:textSize="@dimen/text_size_m"
        android:textColor="@color/text_secundary"
        android:ellipsize="end"
        android:id="@+id/tv_vt_warning_about"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/margin_s"
        android:layout_marginTop="@dimen/margin_l"
        android:layout_marginRight="@dimen/margin_s"
        android:text="@string/vt_report_warning_about"
        android:layout_marginHorizontal="@dimen/margin_s"/>
</LinearLayout>
